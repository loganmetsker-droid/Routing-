{
  "name": "@routing-dispatch/backend",
  "version": "1.0.0",
  "description": "NestJS Backend API for Routing & Dispatching",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/backend/src/main.js",
    "start:prod": "node run-migration.js && node dist/backend/src/main.js",
    "migrate": "node run-migration.js",
    "test": "vitest run --config vitest.config.ts",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "test:cov": "vitest run --config vitest.config.ts --coverage",
    "typeorm": "typeorm-ts-node-commonjs -d src/data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "seed-multi": "ts-node seed-multi.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.9.5",
    "@as-integrations/express5": "^1.1.2",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.17",
    "ansis": "^4.2.0",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "bull": "^4.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^16.3.1",
    "graphql": "^16.8.1",
    "graphql-type-json": "^0.3.2",
    "helmet": "^8.1.0",
    "lru-cache": "7.18.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.11.3",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.2",
    "socket.io": "^4.6.1",
    "stripe": "^20.1.0",
    "typeorm": "^0.3.20",
    "util": "^0.12.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.17",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/passport-jwt": "^4.0.0",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "10.1.0",
    "supertest": "^6.3.3",
    "ts-morph": "^27.0.2",
    "ts-node": "^10.9.2",
    "typeorm-ts-node-commonjs": "^0.3.20",
    "typescript": "^5.3.3",
    "vite": "8.0.9",
    "vitest": "4.1.2"
  }
}
