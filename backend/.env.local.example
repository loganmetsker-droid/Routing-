PORT=3000
FRONTEND_URL=http://127.0.0.1:5184

DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=routing_dispatch
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d
AUTH_ADMIN_EMAIL=admin@routing.local
AUTH_ADMIN_PASSWORD=ChangeMe123!
AUTH_ADMIN_USER_ID=admin-user
AUTH_ADMIN_ROLE=ADMIN
AUTH_ADMIN_ROLES=OWNER,ADMIN

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
ENABLE_SCHEDULER=0
QUEUE_REQUIRED=false

AUTH_PROVIDER=local-config
ALLOW_LOCAL_AUTH=true

STORAGE_MODE=local
