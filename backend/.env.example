NODE_ENV=development
PORT=3000
HOST=0.0.0.0
FRONTEND_URL=http://127.0.0.1:5173

# Database: prefer DATABASE_URL in hosted environments, split vars for local/dev if needed.
DATABASE_URL=
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=routing_dispatch
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DB_POOL_SIZE=5

# Auth
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d
AUTH_ADMIN_EMAIL=admin@routing.local
AUTH_ADMIN_PASSWORD=ChangeMe123!
AUTH_ADMIN_USER_ID=admin-user
AUTH_ADMIN_ROLE=admin

# Queue / worker
QUEUE_REQUIRED=false
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
ENABLE_SCHEDULER=0

# Optimization / routing dependency mode
OPTIMIZATION_MODE=embedded
ROUTING_SERVICE_URL=
ROUTING_PROVIDER_URL=

# Storage / exports
STORAGE_MODE=local
STORAGE_PATH=
DISK_HEALTH_THRESHOLD_PERCENT=0.98

# Startup discipline
STRICT_ENV_VALIDATION=false
