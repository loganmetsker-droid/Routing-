# Docker Compose Environment Variables
# Copy this file to .env and update with your values

# General
NODE_ENV=development
BUILD_TARGET=development

# PostgreSQL/TimescaleDB
POSTGRES_DB=routing_dispatch
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432
POSTGRES_HOST_AUTH_METHOD=scram-sha-256

# Database Connection (for backend)
DATABASE_SYNCHRONIZE=true
DATABASE_LOGGING=true

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here

# Backend API
BACKEND_PORT=3000
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Stripe (get from Stripe Dashboard)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_STARTER=price_starter_plan_id
STRIPE_PRICE_PROFESSIONAL=price_professional_plan_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_plan_id

# Routing Service
ROUTING_SERVICE_PORT=8080
OSRM_MODE=routed
OSRM_THREADS=4

# Frontend
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:3000/api
VITE_GRAPHQL_URL=http://localhost:3000/graphql
VITE_WS_URL=ws://localhost:3000

# CORS
CORS_ORIGIN=http://localhost:5173

# Nginx (for production)
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
