{
  "name": "routing-dispatch-saas",
  "version": "1.0.0",
  "description": "Routing & Dispatching SaaS Platform",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "bootstrap:local": "node scripts/bootstrap-local.mjs",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "test:e2e": "playwright test",
    "capture:ui": "playwright test e2e/ui-audit.spec.ts --project=chromium",
    "smoke:local": "node scripts/local-smoke.mjs",
    "check:backend-deps": "npm ls --workspace=backend @nestjs/common @nestjs/core @nestjs/platform-express @nestjs/typeorm typeorm",
    "docker:dev": "docker-compose -f infrastructure/docker/docker-compose.dev.yml up",
    "docker:prod": "docker-compose -f infrastructure/docker/docker-compose.yml up",
    "k8s:deploy": "kubectl apply -f infrastructure/k8s/"
  },
  "dependencies": {
    "@as-integrations/express5": "^1.1.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "@nestjs/common": "11.1.17",
    "@nestjs/core": "11.1.17",
    "@nestjs/platform-express": "11.1.17"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
